# GitHub Secrets Configuration for PayAI Guardian
# Copy these to your GitHub Repository Settings → Secrets → Actions

# ===========================================
# SERVER ACCESS
# ===========================================
SERVER_HOST=your-server-ip-or-domain.com
SERVER_USER=your-server-username
SERVER_SSH_KEY=<paste-your-ssh-private-key-here>

# ===========================================
# FRONTEND (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# ===========================================
# BACKEND - COMMON
# ===========================================
FRONTEND_URL=https://your-domain.com
DATABASE_URL=postgresql://username:password@host:5432/postgres
JWT_SECRET=your-super-secret-jwt-key-change-this-min-32-characters

# ===========================================
# USER SERVICE (Port 8001)
# ===========================================
# Uses: DATABASE_URL, JWT_SECRET, FRONTEND_URL
JWT_EXPIRE=7d
API_GATEWAY_URL=http://localhost:8000
RESEND_EMAIL_API_KEY=re_your-resend-api-key

# ===========================================
# PAYMENT SERVICE (Port 8002)
# ===========================================
# Uses: DATABASE_URL, JWT_SECRET

# ===========================================
# FRAUD DETECTION SERVICE (Port 8003)
# ===========================================
# Uses: DATABASE_URL, JWT_SECRET

# ===========================================
# AI BANKING SERVICE (Port 8004)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# ANALYTICS SERVICE (Port 8005)
# ===========================================
# Uses: DATABASE_URL

# ===========================================
# NOTIFICATION SERVICE (Port 8006)
# ===========================================
RESEND_EMAIL_API_KEY=re_your-resend-api-key

# ===========================================
# HOW TO SETUP
# ===========================================
# 1. Go to: https://github.com/your-username/payai-guardian/settings/secrets/actions
# 2. Click "New repository secret" for each variable
# 3. Paste the values (without the variable name)
# 4. Save
#
# FOR SSH KEY:
# 1. Run: ssh-keygen -t ed25519 -C "github-actions"
# 2. Run: ssh-copy-id user@your-server
# 3. Run: cat ~/.ssh/id_ed25519
# 4. Copy ENTIRE content (including BEGIN/END lines) to SERVER_SSH_KEY
